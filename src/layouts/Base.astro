---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Cabinet d'avocats spécialisé en droit pénal — Disponible 24h/24.",
} = Astro.props;

const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Custos Avocats',
  description: "Cabinet d'avocats spécialisé en droit pénal.",
  url: 'https://dufi1928.github.io/custos-avocats',
  availableLanguage: 'fr',
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Custos Avocats</title>
    <link rel="icon" href="/custos-avocats/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
    <style is:global>
      /* --- Tokens provisoires (seront remplacés par DA.md) --- */
      :root {
        --noir: #0a0a0a;
        --blanc: #f5f5f0;
        --beton: #c8c8be;
        --ambre: #c8961e;
        --urgence: #b03a2e;

        --font-sans: system-ui, -apple-system, sans-serif;
        --max-width: 1100px;
        --gap: 1.5rem;
        --radius: 4px;
      }

      /* --- Reset minimal --- */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* --- Base --- */
      html { font-size: 16px; scroll-behavior: smooth; }

      body {
        font-family: var(--font-sans);
        background: var(--noir);
        color: var(--blanc);
        line-height: 1.65;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }

      main { flex: 1; }

      /* --- Typographie --- */
      h1 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; font-weight: 700; }
      h2 { font-size: clamp(1.4rem, 3vw, 2rem); line-height: 1.2; font-weight: 600; }
      h3 { font-size: 1.15rem; font-weight: 600; }
      p  { color: var(--beton); max-width: 65ch; }

      a  { color: var(--ambre); text-underline-offset: 3px; }
      a:hover { opacity: 0.8; }

      ul { list-style: none; }

      address { font-style: normal; }

      /* --- Layout utilitaire --- */
      .container {
        width: 100%;
        max-width: var(--max-width);
        margin-inline: auto;
        padding-inline: var(--gap);
      }

      /* --- Banner --- */
      aside[role="note"] {
        background: var(--ambre);
        color: var(--noir);
        text-align: center;
        padding: 0.5rem var(--gap);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.04em;
      }

      aside[role="note"] p { color: inherit; max-width: none; }

      /* --- Header --- */
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--gap);
        padding: 1.25rem var(--gap);
        max-width: var(--max-width);
        margin-inline: auto;
        width: 100%;
      }

      header strong { font-size: 1.2rem; color: var(--blanc); letter-spacing: 0.05em; }
      header a { text-decoration: none; }

      header nav ul {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
      }

      header nav a {
        color: var(--beton);
        font-size: 0.9rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        transition: color 0.2s;
      }

      header nav a:hover { color: var(--blanc); }

      header > a:last-child {
        background: var(--urgence);
        color: var(--blanc);
        padding: 0.55rem 1.1rem;
        border-radius: var(--radius);
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        white-space: nowrap;
        text-decoration: none;
        transition: opacity 0.2s;
      }

      /* --- Main sections --- */
      main section {
        max-width: var(--max-width);
        margin-inline: auto;
        padding: 4rem var(--gap);
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }

      main section h1,
      main section h2,
      main section h3 { margin-bottom: 1rem; }

      main section p { margin-bottom: 1.5rem; }

      main section ul { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }

      /* --- Boutons / CTA --- */
      main a[href] {
        display: inline-block;
        border: 1px solid var(--ambre);
        color: var(--ambre);
        padding: 0.6rem 1.4rem;
        border-radius: var(--radius);
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
      }

      main a[href]:hover {
        background: var(--ambre);
        color: var(--noir);
      }

      /* --- CardAvocat --- */
      article {
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: var(--radius);
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      article header {
        padding: 0;
        max-width: none;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
      }

      article header p { color: var(--beton); font-size: 0.9rem; margin: 0; }
      article header strong { color: var(--ambre); }

      /* --- Page Équipe : grille --- */
      section[aria-label="Les avocats du cabinet"] {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
      }

      /* --- Expertises : liste focus --- */
      ul[aria-label="Points clés"] {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 1rem 0 2rem;
      }

      ul[aria-label="Points clés"] li {
        background: rgba(200, 150, 30, 0.15);
        border: 1px solid var(--ambre);
        color: var(--ambre);
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
      }

      /* --- Formulaire contact --- */
      form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        max-width: 560px;
        margin-top: 1.5rem;
      }

      form div { display: flex; flex-direction: column; gap: 0.4rem; }

      label { font-size: 0.85rem; color: var(--beton); font-weight: 500; }

      input, select, textarea {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.15);
        color: var(--blanc);
        padding: 0.65rem 0.9rem;
        border-radius: var(--radius);
        font-family: inherit;
        font-size: 0.95rem;
        transition: border-color 0.2s;
      }

      input:focus, select:focus, textarea:focus {
        outline: none;
        border-color: var(--ambre);
      }

      select option { background: var(--noir); }

      button[type="submit"] {
        align-self: flex-start;
        background: var(--ambre);
        color: var(--noir);
        border: none;
        padding: 0.7rem 1.6rem;
        border-radius: var(--radius);
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: opacity 0.2s;
      }

      button[type="submit"]:hover { opacity: 0.85; }

      /* --- Footer --- */
      footer {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 2.5rem;
        max-width: var(--max-width);
        margin-inline: auto;
        padding: 3rem var(--gap) 2rem;
        border-top: 1px solid rgba(255,255,255,0.08);
        width: 100%;
      }

      footer h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--beton); margin-bottom: 1rem; }
      footer p, footer a { font-size: 0.85rem; color: rgba(200,200,190,0.6); text-decoration: none; }
      footer ul { gap: 0.6rem; }
      footer a:hover { color: var(--blanc); }

      /* --- Contenu Markdown (expertises) --- */
      .prose h2 { margin: 2rem 0 0.75rem; }
      .prose h3 { margin: 1.5rem 0 0.5rem; color: var(--ambre); }
      .prose p  { margin-bottom: 1rem; }

      /* --- Responsive --- */
      @media (max-width: 640px) {
        header { flex-wrap: wrap; }
        header nav { display: none; }
        main section { padding: 2.5rem var(--gap); }
      }
    </style>
  </head>
  <body>
    <Banner />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
