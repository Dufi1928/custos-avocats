---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const expertises = await getCollection('expertises');
  return expertises.map((entry: CollectionEntry<'expertises'>) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'expertises'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={`Expertise en ${entry.data.title} — Cabinet Custos Avocats.`}>
  <article>
    <header>
      <h1>{entry.data.title}</h1>
      <ul aria-label="Points clés">
        {entry.data.focus.map((point: string) => (
          <li>{point}</li>
        ))}
      </ul>
    </header>

    <div class="prose">
      <Content />
    </div>

    {entry.data.cta && (
      <aside aria-label="Contact">
        <a href="/custos-avocats/contact">{entry.data.cta}</a>
      </aside>
    )}
  </article>
</Base>
