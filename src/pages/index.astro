---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const expertises = await getCollection('expertises');
const sorted = expertises.sort(
  (a: CollectionEntry<'expertises'>, b: CollectionEntry<'expertises'>) =>
    (a.data.ordre ?? 99) - (b.data.ordre ?? 99)
);

const piliers = [
  {
    titre: 'Secret professionnel',
    texte: 'Tout ce que vous nous confiez est protégé sans réserve ni limite dans le temps. Cette garantie est absolue.',
  },
  {
    titre: 'Disponibilité 24h/24',
    texte: 'La garde à vue n\'attend pas. Nos avocats sont joignables à toute heure, week-ends et jours fériés inclus.',
  },
  {
    titre: 'Transparence totale',
    texte: 'Honoraires définis en amont par convention. Stratégie expliquée à chaque étape. Vous décidez en connaissance de cause.',
  },
];
---

<Base
  title="Accueil"
  description="Cabinet d'avocats spécialisé en droit pénal — 5 avocats associés disponibles 24h/24. Garde à vue, comparution immédiate, assises."
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Droit pénal — Disponible 24h/24</p>
        <h1 class="hero-title">
          La défense pénale<br />
          <em>qui ne dort jamais.</em>
        </h1>
        <p class="hero-subtitle">
          Cinq avocats associés à vos côtés, de la garde à vue jusqu'à la cour
          d'assises. Custos intervient quand chaque minute compte.
        </p>
        <div class="hero-actions">
          <a href="/custos-avocats/contact" class="hero-btn hero-btn--primaire">
            Urgence 24h/24
          </a>
          <a href="/custos-avocats/cabinet" class="hero-btn hero-btn--secondaire">
            Le cabinet
          </a>
        </div>
        <ul class="hero-trust">
          <li>Secret professionnel</li>
          <li aria-hidden="true">·</li>
          <li>1ère consultation offerte</li>
          <li aria-hidden="true">·</li>
          <li>Intervention immédiate</li>
        </ul>
      </div>

      <div class="hero-deco" aria-hidden="true">
        <svg viewBox="0 0 320 380" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="159" y="48" width="2" height="240" fill="currentColor" opacity="0.2"/>
          <rect x="72" y="108" width="176" height="2" fill="currentColor" opacity="0.2"/>
          <line x1="105" y1="110" x2="86" y2="178" stroke="currentColor" stroke-width="1.5" opacity="0.25" stroke-dasharray="4 3"/>
          <line x1="215" y1="110" x2="234" y2="178" stroke="currentColor" stroke-width="1.5" opacity="0.25" stroke-dasharray="4 3"/>
          <ellipse cx="86" cy="190" rx="32" ry="11" stroke="currentColor" stroke-width="1.5" fill="currentColor" fill-opacity="0.06" opacity="0.5"/>
          <ellipse cx="234" cy="190" rx="32" ry="11" stroke="currentColor" stroke-width="1.5" fill="currentColor" fill-opacity="0.06" opacity="0.5"/>
          <rect x="124" y="290" width="72" height="2" fill="currentColor" opacity="0.2"/>
          <circle cx="160" cy="56" r="16" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.3"/>
          <circle cx="160" cy="56" r="4" fill="currentColor" opacity="0.25"/>
          <circle cx="160" cy="220" r="72" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.07"/>
          <circle cx="160" cy="220" r="114" stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.04"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="stats-strip" aria-label="Chiffres clés">
    <ul class="stats-grid">
      <li class="stat"><strong>5</strong><span>Avocats associés</span></li>
      <li class="stat"><strong>24h</strong><span>Disponibilité</span></li>
      <li class="stat"><strong>6</strong><span>Pôles d'expertise</span></li>
      <li class="stat"><strong>0€</strong><span>1ère consultation</span></li>
    </ul>
  </section>

  <!-- ============ EXPERTISES ============ -->
  <section class="expertises" aria-label="Nos domaines d'expertise">
    <header class="section-header">
      <p class="eyebrow">Ce que nous défendons</p>
      <h2>Nos domaines d'expertise</h2>
    </header>
    <ul class="expertise-grid">
      {sorted.map((e: CollectionEntry<'expertises'>) => (
        <li>
          <a
            href={`/custos-avocats/expertises/${e.data.slug}`}
            class="expertise-card"
          >
            <span class="expertise-num">
              {String(e.data.ordre ?? 0).padStart(2, '0')}
            </span>
            <h3>{e.data.title}</h3>
            <p>{e.data.focus.slice(0, 2).join(' · ')}</p>
            <span class="expertise-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ============ MISSION ============ -->
  <section class="mission" aria-label="Notre mission">
    <div class="mission-inner">
      <div class="mission-text">
        <p class="eyebrow">Pourquoi Custos</p>
        <h2>Défendre.<br />Protéger.<br />Ne jamais abandonner.</h2>
        <p>
          Nous avons fondé Custos avec une conviction : la défense pénale exige
          autant d'humanité que d'expertise juridique. Chaque client vit une
          situation de crise. Notre rôle est de transformer cette crise en défense.
        </p>
        <a href="/custos-avocats/cabinet" class="mission-lien">Notre mission →</a>
      </div>
      <div class="mission-deco">
        <blockquote class="mission-quote">
          <p>
            "La justice est la constante et perpétuelle volonté d'attribuer à
            chacun son droit."
          </p>
          <cite>Ulpien — Digeste, I, 1, 10</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ============ PILIERS ============ -->
  <section class="piliers" aria-label="Nos engagements">
    <header class="section-header">
      <p class="eyebrow">Nos engagements</p>
      <h2>Ce sur quoi vous pouvez compter</h2>
    </header>
    <ul class="piliers-grid">
      {piliers.map(({ titre, texte }) => (
        <li class="pilier">
          <h3>{titre}</h3>
          <p>{texte}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- ============ ÉQUIPE PREVIEW ============ -->
  <section class="equipe-preview" aria-label="L'équipe">
    <div class="equipe-text">
      <p class="eyebrow">Cinq associés</p>
      <h2>Une équipe, un seul objectif : votre défense</h2>
      <p>
        Chaque avocat du cabinet partage un socle commun en droit pénal et porte
        une spécialité complémentaire. Ensemble, nous couvrons l'intégralité du
        spectre pénal.
      </p>
      <a href="/custos-avocats/equipe" class="equipe-lien">Rencontrer l'équipe →</a>
    </div>
  </section>

  <!-- ============ URGENCE CTA ============ -->
  <section class="urgence-cta" aria-label="Contact urgence">
    <p class="eyebrow urgence-eyebrow">Disponible maintenant</p>
    <h2>Une urgence en ce moment ?</h2>
    <p>Nos avocats répondent. À n'importe quelle heure.</p>
    <a href="/custos-avocats/contact" class="urgence-btn">Nous contacter</a>
  </section>
</Base>

<style>
/* ---- RESET SECTIONS PLEINE LARGEUR ---- */
.hero,
.stats-strip,
.mission,
.urgence-cta {
  max-width: 100%;
  width: 100%;
  padding: 0;
  border-bottom: none;
}

/* ======================================
   HERO
   ====================================== */
.hero { background: #1A1A1A; }

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 4rem;
  max-width: var(--max-width);
  margin-inline: auto;
  padding: 7rem var(--gap) 6rem;
  min-height: 90vh;
}

.hero-eyebrow {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--vert-vif);
  font-weight: 600;
  margin-bottom: 1.75rem;
  max-width: none;
  animation: heroFadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(1.9rem, 3.2vw, 3rem);
  font-weight: 700;
  line-height: 1.12;
  color: #F4F5F2;
  margin-bottom: 1.5rem;
  animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both;
}

.hero-title em {
  font-style: italic;
  color: var(--vert-vif);
}

.hero-subtitle {
  font-size: 1.05rem;
  color: rgba(244, 245, 242, 0.55);
  max-width: 50ch;
  line-height: 1.8;
  margin-bottom: 2.5rem;
  animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.24s both;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
  animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.36s both;
}

.hero-btn {
  display: inline-block;
  padding: 0.85rem 1.75rem;
  border-radius: var(--radius);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.07em;
  text-decoration: none;
  text-transform: uppercase;
  transition: all 0.25s ease;
  border: 1px solid transparent;
}

.hero-btn--primaire {
  background: var(--vert);
  color: #F4F5F2;
  border-color: var(--vert);
}
.hero-btn--primaire:hover {
  background: var(--vert-vif);
  border-color: var(--vert-vif);
  color: #F4F5F2;
  opacity: 1;
}

.hero-btn--secondaire {
  background: transparent;
  color: rgba(244, 245, 242, 0.65);
  border-color: rgba(244, 245, 242, 0.2);
}
.hero-btn--secondaire:hover {
  border-color: rgba(244, 245, 242, 0.5);
  color: #F4F5F2;
  background: transparent;
  opacity: 1;
}

.hero-trust {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  flex-wrap: wrap;
  flex-direction: row;
  margin-top: 0;
  animation: heroFadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
}
.hero-trust li {
  font-size: 0.7rem;
  color: rgba(244, 245, 242, 0.32);
  letter-spacing: 0.03em;
}

.hero-deco {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: var(--vert-vif);
  animation: heroFadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
}
.hero-deco svg { width: 85%; max-width: 300px; height: auto; }

@keyframes heroFadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ======================================
   STATS
   ====================================== */
.stats-strip {
  background: var(--blanc);
  border-bottom: 1px solid var(--gris-clair);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  max-width: var(--max-width);
  margin-inline: auto;
  flex-direction: row;
  gap: 0;
  margin-top: 0;
}

.stat {
  padding: 2.5rem 2rem;
  border-right: 1px solid var(--gris-clair);
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.stat:last-child { border-right: none; }

.stat strong {
  font-family: var(--font-serif);
  font-size: 2.75rem;
  color: var(--vert);
  line-height: 1;
}

.stat span {
  font-size: 0.7rem;
  color: var(--gris);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 500;
}

/* ======================================
   EXPERTISES
   ====================================== */
.expertises { padding: 6rem var(--gap); }

.section-header { margin-bottom: 3rem; }
.section-header h2 { margin-bottom: 0; }

.eyebrow {
  display: block;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--vert);
  font-weight: 600;
  margin-bottom: 0.75rem;
  max-width: none;
}

.expertise-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  background: var(--gris-clair);
  border: 1px solid var(--gris-clair);
  border-radius: var(--radius);
  overflow: hidden;
  flex-direction: unset;
  margin-top: 0;
}

.expertise-card {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  padding: 2.25rem 2rem;
  background: var(--fond);
  text-decoration: none;
  transition: background 0.25s;
  border: none;
  border-radius: 0;
  color: var(--texte);
}
.expertise-card:hover {
  background: var(--blanc);
  color: var(--texte);
  opacity: 1;
}

.expertise-num {
  display: block;
  font-size: 0.65rem;
  color: var(--gris);
  font-weight: 500;
  letter-spacing: 0.08em;
  margin-bottom: 0.5rem;
}

.expertise-card h3 {
  font-family: var(--font-serif);
  font-size: 1.05rem;
  color: var(--texte);
  font-weight: 700;
  margin-bottom: 0.2rem;
}

.expertise-card p {
  font-size: 0.78rem;
  color: var(--gris);
  max-width: none;
  margin: 0;
  line-height: 1.5;
}

.expertise-arrow {
  display: block;
  margin-top: auto;
  padding-top: 1.5rem;
  font-size: 0.9rem;
  color: var(--vert);
  transition: transform 0.25s;
}
.expertise-card:hover .expertise-arrow { transform: translateX(5px); }

/* ======================================
   MISSION
   ====================================== */
.mission {
  background: #ECECE7;
  border-top: 1px solid var(--gris-clair);
  border-bottom: 1px solid var(--gris-clair) !important;
}

.mission-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
  max-width: var(--max-width);
  margin-inline: auto;
  padding: 7rem var(--gap);
}

.mission-text .eyebrow { margin-bottom: 1rem; }

.mission-text h2 {
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  line-height: 1.15;
  margin-bottom: 1.75rem;
}

.mission-text p {
  max-width: 48ch;
  margin-bottom: 2.25rem;
  font-size: 0.95rem;
}

.mission-lien {
  display: inline-block;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--vert);
  text-decoration: none;
  border: none;
  padding: 0;
  border-radius: 0;
  transition: color 0.25s;
}
.mission-lien:hover { color: var(--vert-vif); background: transparent; opacity: 1; }

.mission-quote {
  border-left: 3px solid var(--vert);
  padding: 2.5rem 2.5rem 2.5rem 2.75rem;
  background: var(--blanc);
  border-radius: 0 var(--radius) var(--radius) 0;
  box-shadow: 0 4px 32px rgba(0, 0, 0, 0.07);
}

.mission-quote p {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  font-style: italic;
  color: var(--anthracite);
  line-height: 1.75;
  max-width: none;
  margin: 0 0 1.5rem;
}

.mission-quote cite {
  display: block;
  font-size: 0.7rem;
  font-style: normal;
  color: var(--gris);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-family: var(--font-sans);
  font-weight: 600;
}

/* ======================================
   PILIERS
   ====================================== */
.piliers { padding: 6rem var(--gap); }
.piliers .section-header { margin-bottom: 3.5rem; }

.piliers-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3rem;
  flex-direction: row;
  margin-top: 0;
}

.pilier {
  padding-top: 1.75rem;
  border-top: 2px solid var(--vert);
}

.pilier h3 {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  margin-bottom: 0.75rem;
  color: var(--texte);
}

.pilier p { font-size: 0.9rem; line-height: 1.75; max-width: none; margin: 0; }

/* ======================================
   ÉQUIPE PREVIEW
   ====================================== */
.equipe-preview { padding: 6rem var(--gap); }

.equipe-text .eyebrow { margin-bottom: 1rem; }
.equipe-text h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); margin-bottom: 1.25rem; }
.equipe-text p { max-width: 60ch; margin-bottom: 2rem; font-size: 0.95rem; }

.equipe-lien {
  display: inline-block;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--vert);
  text-decoration: none;
  border: 1px solid var(--vert);
  padding: 0.7rem 1.5rem;
  border-radius: var(--radius);
  transition: all 0.25s;
}
.equipe-lien:hover { background: var(--vert); color: var(--blanc); opacity: 1; }

/* ======================================
   URGENCE CTA
   ====================================== */
.urgence-cta {
  background: #1A1A1A;
  padding: 7rem var(--gap);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  border-bottom: none !important;
}

.urgence-eyebrow { color: var(--vert-vif); }

.urgence-cta h2 { color: #F4F5F2; font-size: clamp(1.75rem, 4vw, 3rem); margin: 0; }
.urgence-cta p { color: rgba(244, 245, 242, 0.45); max-width: none; margin: 0; }

.urgence-btn {
  display: inline-block;
  margin-top: 1.25rem;
  background: var(--vert);
  color: #F4F5F2;
  padding: 1rem 2.5rem;
  border-radius: var(--radius);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  text-decoration: none;
  border: 1px solid var(--vert);
  transition: background 0.25s, border-color 0.25s;
}
.urgence-btn:hover {
  background: var(--vert-vif);
  border-color: var(--vert-vif);
  color: #F4F5F2;
  opacity: 1;
}

/* ======================================
   RESPONSIVE
   ====================================== */
@media (max-width: 900px) {
  .hero-inner {
    grid-template-columns: 1fr;
    min-height: auto;
    padding: 5rem var(--gap) 4rem;
  }
  .hero-deco { display: none; }
  .expertise-grid { grid-template-columns: repeat(2, 1fr); }
  .mission-inner { grid-template-columns: 1fr; gap: 3rem; padding: 5rem var(--gap); }
  .piliers-grid { grid-template-columns: 1fr; gap: 2rem; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .stat:nth-child(2) { border-right: none; }
  .stat:nth-child(3) { border-top: 1px solid var(--gris-clair); }
  .stat:nth-child(4) { border-top: 1px solid var(--gris-clair); border-right: none; }
}

@media (max-width: 600px) {
  .expertise-grid { grid-template-columns: 1fr; }
}
</style>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

if (!noMotion) {
  gsap.from('.stat', {
    scrollTrigger: { trigger: '.stats-strip', start: 'top 88%' },
    y: 25, autoAlpha: 0, duration: 0.55, stagger: 0.1, ease: 'power3.out',
  });

  gsap.from('.expertise-card', {
    scrollTrigger: { trigger: '.expertise-grid', start: 'top 82%' },
    y: 35, autoAlpha: 0, duration: 0.5, stagger: 0.06, ease: 'power3.out',
  });

  gsap.utils.toArray<HTMLElement>('.section-header').forEach((el) => {
    gsap.from(Array.from(el.children), {
      scrollTrigger: { trigger: el, start: 'top 88%' },
      y: 20, autoAlpha: 0, duration: 0.6, stagger: 0.1, ease: 'power3.out',
    });
  });

  gsap.from('.mission-text > *', {
    scrollTrigger: { trigger: '.mission-inner', start: 'top 80%' },
    y: 30, autoAlpha: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out',
  });

  gsap.from('.mission-quote', {
    scrollTrigger: { trigger: '.mission-inner', start: 'top 75%' },
    x: 40, autoAlpha: 0, duration: 0.8, ease: 'power3.out',
  });

  gsap.from('.pilier', {
    scrollTrigger: { trigger: '.piliers-grid', start: 'top 85%' },
    y: 35, autoAlpha: 0, duration: 0.6, stagger: 0.15, ease: 'power3.out',
  });

  gsap.from('.equipe-text > *', {
    scrollTrigger: { trigger: '.equipe-preview', start: 'top 85%' },
    y: 25, autoAlpha: 0, duration: 0.6, stagger: 0.1, ease: 'power3.out',
  });

  gsap.from('.urgence-cta > *', {
    scrollTrigger: { trigger: '.urgence-cta', start: 'top 85%' },
    y: 25, autoAlpha: 0, duration: 0.6, stagger: 0.12, ease: 'power3.out',
  });
}
</script>
