---
import Base from '../layouts/Base.astro';
---

<Base title="Honoraires" description="Transparence tarifaire du cabinet Custos Avocats. Aide Juridictionnelle acceptée.">
  <section aria-label="Présentation des honoraires">
    <h1>Honoraires</h1>
    <p>
      Le cabinet Custos s'engage à une totale transparence sur ses honoraires.
      Une convention d'honoraires est systématiquement établie avant toute intervention.
    </p>
  </section>

  <section aria-label="Modalités de facturation">
    <h2>Modalités</h2>
    <ul>
      <li>
        <h3>Honoraire au temps passé</h3>
        <p>Facturation sur la base du temps effectivement consacré à votre dossier.</p>
      </li>
      <li>
        <h3>Honoraire forfaitaire</h3>
        <p>Forfait défini en amont pour les procédures à périmètre déterminé.</p>
      </li>
      <li>
        <h3>Honoraire de résultat</h3>
        <p>Complément d'honoraire conditionné au résultat obtenu, en sus du fixe.</p>
      </li>
    </ul>
  </section>

  <section aria-label="Aide Juridictionnelle">
    <h2>Aide Juridictionnelle</h2>
    <p>
      Le cabinet accepte les missions au titre de l'aide juridictionnelle totale ou partielle.
      N'hésitez pas à nous contacter pour évaluer votre éligibilité.
    </p>
    <a href="/custos-avocats/contact">Nous contacter</a>
  </section>

  <section aria-label="Première consultation">
    <h2>Première consultation offerte</h2>
    <p>
      La première consultation est offerte. Elle vous permet d'exposer votre situation
      et d'obtenir une première analyse juridique sans engagement.
    </p>
    <a href="/custos-avocats/contact">Prendre rendez-vous</a>
  </section>
</Base>
